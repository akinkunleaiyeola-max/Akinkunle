@model ATMPOSONLINE.Models.Loan

<h3>Confirm Loan Approval</h3>

<div class="card p-4">
    <p><strong>Full Name:</strong> @Model.FullName</p>
    <p><strong>Account Number:</strong> @Model.AccountNumber</p>
    <p><strong>Loan Amount:</strong> ₦@Model.Amount</p>
    <p><strong>Total Repayment:</strong> ₦@Model.TotalRepayment</p>
    <p><strong>Date Applied:</strong> @Model.DateApplied</p>
    <p><strong>Status:</strong> @Model.Status</p>

    <form method="post" asp-action="ApproveLoan">
        <input type="hidden" name="id" value="@Model.Id" />

        <button type="submit" class="btn btn-success">Confirm Approval</button>
        <a asp-action="ApproveLoan" class="btn btn-danger">Cancel</a>
    </form>
</div>