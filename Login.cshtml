@using ATMPOSONLINE.ViewModels;
@model LoginViewModel;
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}
<div class="Account-container">
    <div class="account-box">
        <h2 class="text-center mb-3">Welcome </h2>
        <p class="text-center text-muted mb-4">Sign-in to access your account</p>

        <form asp-action="Login" method="post" class="form-card">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control form-control-lg" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password" type="password" class="form-control form-control-lg" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label class="form-check-label">@Html.DisplayNameFor(m => m.RememberMe)</label>
                </div>
                <div>
                    <a asp-controller="Account" asp-action="VerifyEmail" class="link-secondary">Forgot password?</a>
                </div>
            </div>
            <button type="submit" class="btn btn-primary w-100 btn-lg">Sign in</button>
            <p class="text-center mt-3 small text-muted">
                Don't have an account? <a asp-controller="Account" asp-action="Register">Create one</a>
            </p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary w-100 mt-2">Back</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
