@model ATMPOSONLINE.ViewModels.LoanViewModel

<div class="d-flex justify-content-between align-items-center mb-3">
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div class="text-muted">Welcome, <strong>@User.Identity.Name</strong></div>
    }

    <div>
        <a asp-controller="Transactions" asp-action="History" class="btn btn-outline-secondary btn-sm">History</a>
    </div>
</div>

@if (TempData["Balance"] != null)
{
    <div class="alert alert-success d-flex justify-content-between align-items-center">
        <div>
            <small class="text-muted">Current Balance</small>
            <div class="fw-bold">₦@TempData["Balance"]</div>
        </div>
    </div>
}
@{
    TempData.Keep("Balance");
}

<div class="card-modern col-12 col-md-8 col-lg-6 mx-auto">
    <div class="card-header-modern d-flex align-items-center justify-content-between mb-3">
        <h4 class="mb-0">Loan Application</h4>
        <small class="text-muted">Evaluate • Apply • Track</small>
    </div>

    <div class="p-4">
        <form method="post" asp-controller="Transactions" asp-action="ApplyLoan">
            <div asp-validation-summary="All" class="text-danger mb-2"></div>
            <div class="mb-3">
                <label asp-for="AccountNumber" class="form-label">Account Number</label>
                <input asp-for="AccountNumber" id="AccountNumber" class="form-control form-control-lg" placeholder="Enter account number" />
            </div>
            <div class="mb-3">
                <label asp-for="FullName" class="form-label">Full name</label>
                <input asp-for="FullName" id="FullName" class="form-control form-control-lg" readonly />
            </div>
            <div class="mb-3">
                <label asp-for="Amount" class="form-label">Requested amount</label>
                <div class="input-group">
                    <span class="input-group-text">₦</span>
                    <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0" />
                </div>
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">Apply</button>
                <a asp-controller="Transaction_Page" asp-action="Transaction" class="btn btn-outline-secondary">Back</a>
            </div>
        </form>
    </div>
</div>
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const accountInput = document.getElementById("AccountNumber");
            const fullNameInput = document.getElementById("FullName");

            if (accountInput) {
                accountInput.addEventListener("keyup", function () {
                    let accountNumber = accountInput.value;
                    if (accountNumber.length >= 10) {
                        fullNameInput.value = "Checking...";
                        fetch('/Transactions/GetAccountName?accountNumber=' + encodeURIComponent(accountNumber))
                            .then(response => response.json())
                            .then(data => fullNameInput.value = data || "Account not found")
                            .catch(() => fullNameInput.value = "Error");
                    } else {
                        fullNameInput.value = "";
                    }
                });
            }
        });
    </script>
}